{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fantune.app/schemas/FanTuneProfile.json",
  "title": "FanTuneProfile",
  "description": "Measured fan acoustic profile for FanTune DSP engine. Generated by analyze_fan_profile.py",
  "type": "object",
  "required": ["profile_meta", "bpf", "am_envelope", "comb_filter", "motor_hum", "spectral_chop"],

  "properties": {
    "profile_meta": {
      "type": "object",
      "description": "Capture metadata and provenance",
      "required": ["source_file", "analysis_timestamp", "sample_rate", "blade_count", "geometry", "speed_caption"],
      "properties": {
        "source_file":     { "type": "string", "description": "Original WAV filename" },
        "analysis_timestamp": { "type": "string", "format": "date-time" },
        "sample_rate":     { "type": "integer", "minimum": 44100, "maximum": 192000 },
        "blade_count":     { "type": "integer", "minimum": 2, "maximum": 5, "default": 3 },
        "geometry":        { "type": "string", "enum": ["grille", "behind", "di"], "description": "Mic position relative to fan" },
        "speed_caption":   { "type": "string", "enum": ["low", "med", "high"], "description": "Fan speed setting" },
        "fan_id":          { "type": "string", "description": "Fan make/model identifier" },
        "mic_distance_cm": { "type": "number", "description": "Mic distance from fan surface in cm" }
      }
    },

    "bpf": {
      "type": "object",
      "description": "Blade-pass frequency = rotation_Hz * blade_count",
      "required": ["measured_hz"],
      "properties": {
        "measured_hz":   { "type": "number", "minimum": 10, "maximum": 100, "description": "Fundamental blade-pass frequency from Welch PSD peak" },
        "confidence":    { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Peak-to-floor ratio of BPF harmonic in spectrum" }
      }
    },

    "am_envelope": {
      "type": "object",
      "description": "Asymmetric amplitude modulation envelope from blade pass. This is the PRIMARY mechanism.",
      "required": ["depth_db", "duty_cycle", "rise_time_ms", "fall_time_ms", "asymmetry_ratio"],
      "properties": {
        "depth_db":        { "type": "number", "minimum": 0, "maximum": 60, "description": "20*log10(peak/trough) averaged over cycles. 0 = no chop, 40+ = hard gate" },
        "duty_cycle":      { "type": "number", "minimum": 0.05, "maximum": 0.95, "description": "Fraction of period where envelope > 50% max. Lower = narrower open window." },
        "rise_time_ms":    { "type": "number", "minimum": 0.05, "maximum": 50.0, "description": "Envelope 10%→90% rise time" },
        "fall_time_ms":    { "type": "number", "minimum": 0.05, "maximum": 50.0, "description": "Envelope 90%→10% fall time" },
        "asymmetry_ratio": { "type": "number", "minimum": 0.02, "maximum": 50.0, "description": "rise_time / fall_time. >1 = fast rise slow open (obstruct), <1 = slow approach fast open" }
      }
    },

    "comb_filter": {
      "type": "object",
      "description": "Housing/plastic cavity comb filtering. Multiple short reflections within the fan housing.",
      "required": ["tap_delays_ms", "tap_gains_db"],
      "properties": {
        "tap_delays_ms": {
          "type": "array",
          "items": { "type": "number", "minimum": 0.01, "maximum": 10.0 },
          "minItems": 0,
          "maxItems": 8,
          "description": "Delay times of significant comb reflections in ms (0.1–5 ms typical)"
        },
        "tap_gains_db": {
          "type": "array",
          "items": { "type": "number", "minimum": -60, "maximum": 0 },
          "minItems": 0,
          "maxItems": 8,
          "description": "Gain of each tap in dB re: direct path"
        },
        "peak_spacing_hz":   { "type": "number", "description": "Fundamental comb frequency = 1 / mean(tap spacing in seconds)" },
        "correlation_strength": { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Peak autocorrelation value of strongest comb tap" }
      }
    },

    "motor_hum": {
      "type": "object",
      "description": "Motor electromagnetic hum at 60/120 Hz and BPF sideband modulation",
      "required": ["hum_60_db", "hum_120_db"],
      "properties": {
        "hum_60_db":        { "type": "number", "description": "60 Hz fundamental magnitude in dB above noise floor" },
        "hum_120_db":       { "type": "number", "description": "120 Hz (2nd harmonic) magnitude in dB above noise floor" },
        "bpf_sideband_db":  { "type": "number", "description": "BPF ± 60 Hz sideband energy in dB above noise floor" },
        "harmonic_count":   { "type": "integer", "minimum": 0, "maximum": 20, "description": "Number of detectable 60 Hz harmonics" }
      }
    },

    "spectral_chop": {
      "type": "object",
      "description": "Frequency-dependent chop behavior: HF attenuates more than LF during blade obstruction.",
      "required": ["hf_attenuation_db", "low_band_am_depth_db", "high_band_am_depth_db"],
      "properties": {
        "hf_attenuation_db":  { "type": "number", "description": "Additional HF (> 3 kHz) attenuation during blade close relative to blade open" },
        "crossover_hz":       { "type": "number", "description": "Frequency where vocal vs noise ratio crosses 3 dB" },
        "low_band_am_depth_db": { "type": "number", "description": "AM depth in 72–820 Hz band" },
        "high_band_am_depth_db": { "type": "number", "description": "AM depth in 820 Hz–12 kHz band" }
      }
    },

    "scoring": {
      "type": "object",
      "description": "Offline regression scores when comparing model output to reference (optional)",
      "properties": {
        "envelope_rmse":            { "type": "number", "minimum": 0, "description": "RMSE between normalized envelopes" },
        "spectral_am_correlation":  { "type": "number", "minimum": -1, "maximum": 1, "description": "Correlation of spectrogram AM profiles" },
        "comb_correlation":         { "type": "number", "minimum": -1, "maximum": 1, "description": "Correlation of autocorrelation comb patterns" },
        "am_depth_error_db":        { "type": "number", "description": "Absolute AM depth difference" },
        "duty_cycle_error":         { "type": "number", "minimum": 0, "maximum": 1, "description": "Absolute duty cycle difference" },
        "overall_score":            { "type": "number", "minimum": 0, "maximum": 1, "description": "Weighted composite score (see SCORING_METRICS.md)" }
      }
    }
  },

  "examples": [
    {
      "profile_meta": {
        "source_file": "f_lasko20_g_behind_s2_p01.wav",
        "analysis_timestamp": "2026-06-14T10:30:00Z",
        "sample_rate": 48000,
        "blade_count": 3,
        "geometry": "behind",
        "speed_caption": "med",
        "fan_id": "lasko20",
        "mic_distance_cm": 15.2
      },
      "bpf": {
        "measured_hz": 36.2,
        "confidence": 0.92
      },
      "am_envelope": {
        "depth_db": 18.3,
        "duty_cycle": 0.42,
        "rise_time_ms": 2.14,
        "fall_time_ms": 1.38,
        "asymmetry_ratio": 1.55
      },
      "comb_filter": {
        "tap_delays_ms": [0.38, 0.81, 1.24, 1.92, 2.87, 3.46],
        "tap_gains_db": [-8.2, -12.6, -15.1, -18.4, -21.7, -24.0],
        "peak_spacing_hz": 324.0,
        "correlation_strength": 0.38
      },
      "motor_hum": {
        "hum_60_db": -32.4,
        "hum_120_db": -28.1,
        "bpf_sideband_db": -38.7,
        "harmonic_count": 4
      },
      "spectral_chop": {
        "hf_attenuation_db": -14.2,
        "crossover_hz": 3200.0,
        "low_band_am_depth_db": 14.8,
        "high_band_am_depth_db": 21.6
      }
    }
  ]
}
